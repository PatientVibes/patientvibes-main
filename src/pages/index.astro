---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectRow from '../components/ProjectRow.astro';
import NoteRow from '../components/NoteRow.astro';
import BenchPanel from '../components/BenchPanel.astro';
import Terminal from '../components/Terminal.astro';
import { loadProjects, byKind, displayStatus, formatYearMonth, shortId, type Project } from '../lib/load-projects';

// Render markdown-style `inline code` from catalog summaries as coral pv-mono spans.
const codeStyle = 'color:var(--pv-coral);font-size:13px;';
const renderDesc = (s: string) =>
  s.replace(/`([^`]+)`/g, (_, code) => `<code class="pv-mono" style="${codeStyle}">${code}</code>`);

const catalog = await loadProjects();
const allProjects = catalog.projects;

const fromCatalog = (kind: Project['kind']) =>
  byKind(allProjects, kind).map((p, i) => {
    const ds = displayStatus(p.status);
    return {
      id: shortId(kind, i + 1),
      href: p.url,
      name: p.name,
      description: renderDesc(p.summary),
      status: ds.state,
      statusLabel: ds.label,
      meta: [],
      date: formatYearMonth(p.last_run),
    };
  });

const harnesses = fromCatalog('harness');
const tools     = fromCatalog('tool');
const skills    = fromCatalog('skill');

// Workshop entries stay hardcoded — hardware projects aren't in the agents catalog.
const workshop = [
  {
    id: 'W–01',
    href: '#',
    name: 'hotel <span class="v">/ esp32 door scanner</span>',
    status: 'build' as const,
    statusLabel: 'building',
    description: `My son got tired of asking for the lights. Now he swipes a hotel keycard, the bedroom lights come up, and the speaker says hi back. ESP32, an RFID reader, and far too much enthusiasm.`,
    meta: [
      { k: 'hw', v: 'esp32 · rc522 · ws2812' },
      { k: 'tags', v: 'esp32 · home' },
    ],
    date: '2025 · 12',
  },
  {
    id: 'W–02',
    href: '#',
    name: 'desk parts <span class="v">/ small printed things</span>',
    status: 'draft' as const,
    statusLabel: 'drafting',
    description: `A collection-in-progress of printable parts I've designed for myself — cable combs, monitor risers, mounts for the things that don't ship with mounts. STL + notes on what failed before it worked.`,
    meta: [
      { k: 'tool', v: 'fusion 360 · prusa mk4' },
      { k: 'tags', v: '3d-print' },
    ],
    date: '2025 · 11',
  },
];

const notes = [
  { date: '2026 · 04 · 18', title: 'On <em>patient</em> agents — why I stopped optimizing for fast.', href: '#', readMin: 7 },
  { date: '2026 · 04 · 02', title: 'The harness comes first. The model comes last.',                 href: '#', readMin: 5 },
  { date: '2026 · 03 · 21', title: 'Tools should be <em>boring</em>, like good libraries.',          href: '#', readMin: 4 },
  { date: '2026 · 02 · 09', title: 'A weekend with the ESP32 — notes for next time.',               href: '#', readMin: 6 },
];

// Bench panel: most-recently-updated 5 from the catalog. status === 'dev' renders as
// "in flight"; any other status renders as "shipped" with the year/month it pulled.
const recent = [...allProjects].sort((a, b) => b.last_run.localeCompare(a.last_run)).slice(0, 5);
const benchItems = recent.map(p => ({
  state: (p.status === 'dev' ? 'flight' : 'shipped') as 'flight' | 'shipped' | 'queued',
  label: p.name,
  tag: p.kind,
  when: p.status === 'dev' ? 'in&nbsp;flight' : formatYearMonth(p.last_run),
}));
const inFlightCount = benchItems.filter(i => i.state === 'flight').length;

const tags = [
  { name: 'tool', n: 8 },
  { name: 'harness', n: 1 },
  { name: 'skill', n: 1 },
  { name: 'ocr', n: 4 },
  { name: 'kindle', n: 3 },
  { name: 'pr-review', n: 2 },
  { name: 'esp32', n: 1 },
  { name: '3d-print', n: 1 },
  { name: 'essay', n: 3 },
];
---
<BaseLayout
  title="patientvibes — a workshop for patient things"
  description="Chris Moore's portfolio: AI agents, the tools they need, and the harnesses that keep them honest."
>
<div class="hp">

  <!-- ── Nav ── -->
  <nav class="hp-nav">
    <div class="hp-nav__brand">
      <span class="glyph">pv</span>
      <span class="name">patientvibes</span>
    </div>
    <div class="hp-nav__meta">
      <a href="#projects">Projects</a>
      <a href="#notes">Notes</a>
      <a href="#now">Now</a>
      <a href="https://agents.patientvibes.io">Agents</a>
      <span class="live"><i></i>online</span>
    </div>
  </nav>

  <!-- ── Hero ── -->
  <header class="hp-hero">
    <div class="hp-hero__greet"><i></i>Index · v3 · updated today</div>
    <h1 class="hp-hero__title">A workshop for <em>patient</em> things.</h1>
    <div class="hp-hero__intro">
      <div>
        <p>I build slow software — agents, the tools they need, and the harnesses that keep them honest. This is where the finished work lives, and where the half-finished work gets honest about it.</p>
        <p>Most of it is published as a public catalog at <a href="https://agents.patientvibes.io">agents.patientvibes.io</a> — skills, tools, and harnesses, READMEs pulled live from each source repo. Soon: 3D-printed parts and an ESP32 build my son keeps asking me to finish.</p>
      </div>
      <aside class="hp-card-tags">
        <div class="hp-card-tags__head"><span>Tags</span><span>{tags.length}</span></div>
        <div class="hp-card-tags__list">
          {tags.map(t => (
            <a href="#"><span>{t.name}</span><span class="n">{t.n}</span></a>
          ))}
        </div>
      </aside>
    </div>
  </header>

  <!-- ── Harnesses ── -->
  <section id="projects" class="hp-sec">
    <div class="hp-sec__head">
      <div class="hp-sec__title">
        <span class="hp-sec__num">01 · Harnesses</span>
        <h2 class="hp-sec__name">The orchestrators.</h2>
      </div>
      <span class="hp-sec__count">{String(harnesses.length).padStart(2, '0')} entry</span>
    </div>
    {harnesses.map(p => <ProjectRow {...p} />)}
  </section>

  <!-- ── Tools ── -->
  <section class="hp-sec">
    <div class="hp-sec__head">
      <div class="hp-sec__title">
        <span class="hp-sec__num">02 · Tools</span>
        <h2 class="hp-sec__name">Single-purpose CLIs.</h2>
      </div>
      <span class="hp-sec__count">{String(tools.length).padStart(2, '0')} entries</span>
    </div>
    {tools.map(p => <ProjectRow {...p} />)}
  </section>

  <!-- ── Skills ── -->
  <section class="hp-sec">
    <div class="hp-sec__head">
      <div class="hp-sec__title">
        <span class="hp-sec__num">03 · Skills</span>
        <h2 class="hp-sec__name">For Claude Code.</h2>
      </div>
      <span class="hp-sec__count">{String(skills.length).padStart(2, '0')} entry</span>
    </div>
    {skills.map(p => <ProjectRow {...p} />)}
  </section>

  <!-- ── Workshop (non-agent) ── -->
  <section class="hp-sec">
    <div class="hp-sec__head">
      <div class="hp-sec__title">
        <span class="hp-sec__num">04 · Workshop</span>
        <h2 class="hp-sec__name">Off the screen.</h2>
      </div>
      <span class="hp-sec__count">{String(workshop.length).padStart(2, '0')} entries</span>
    </div>
    {workshop.map(p => <ProjectRow {...p} />)}
  </section>

  <!-- ── Notes ── -->
  <section id="notes" class="hp-sec">
    <div class="hp-sec__head">
      <div class="hp-sec__title">
        <span class="hp-sec__num">05 · Notes</span>
        <h2 class="hp-sec__name">Things I'm writing about.</h2>
      </div>
      <span class="hp-sec__count">{String(notes.length).padStart(2, '0')} entries</span>
    </div>
    {notes.map(n => <NoteRow {...n} />)}
  </section>

  <!-- ── Now ── -->
  <section id="now" class="hp-sec">
    <div class="hp-sec__head">
      <div class="hp-sec__title">
        <span class="hp-sec__num">06 · Now</span>
        <h2 class="hp-sec__name">What's on the bench.</h2>
      </div>
      <span class="hp-sec__count">updated 2d ago</span>
    </div>

    <div class="hp-now">
      <div class="hp-now__body">
        <p class="hp-now__quote">"Building slowly is the only way I know how to build things I keep using."</p>
        <p class="hp-now__sub">Right now I'm cleaning up the harness write-up, running triage in production against my own inbox, and trying to teach the ESP32 to recognize three different cards before it pretends to be a butler.</p>
      </div>
      {benchItems.length > 0
        ? <BenchPanel inFlightCount={inFlightCount} items={benchItems} />
        : <p class="hp-now__sub" style="margin-top: 0;"><span class="pv-mono" style="text-transform: uppercase; letter-spacing: var(--pv-track-eyebrow); color: var(--pv-mute);">currently · </span>kindle-pipeline · book #2.</p>
      }
    </div>

    <div class="hp-term-wrap">
      <Terminal />
    </div>
  </section>

  <!-- ── Footer ── -->
  <footer class="hp-foot">
    <div class="hp-foot__signoff">
      Built in the <em>open</em>,<br />shipped when it's ready.
    </div>
    <div class="hp-foot__links">
      <a href="https://github.com/PatientVibes">github · /patientvibes</a>
      <a href="/index.xml">rss · /index.xml</a>
      <a href="mailto:hi@patientvibes.io">email · hi@patientvibes.io</a>
    </div>
    <div class="hp-foot__colophon">
      <span>© patientvibes · 2026</span>
      <span>set in instrument serif, inter, jetbrains mono</span>
    </div>
  </footer>

</div>
</BaseLayout>

<style is:global>
  /* page chrome — global because .hp-proj/.hp-note/.hp-now target elements
     rendered by imported components (ProjectRow, NoteRow, BenchPanel), which
     get a different scope hash than this page's <style> block. */
  .hp { max-width: 980px; margin: 0 auto; padding: var(--pv-6) var(--pv-6) var(--pv-9); }

  /* nav row */
  .hp-nav { display: flex; align-items: center; justify-content: space-between; padding: 8px 0 28px; border-bottom: 1px solid var(--pv-ink); }
  .hp-nav__brand { display: flex; align-items: center; gap: 12px; }
  .hp-nav__brand .glyph {
    width: 32px; height: 32px;
    border: 1.4px solid var(--pv-sage); color: var(--pv-sage);
    border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    font: italic 16px/1 var(--pv-font-serif);
  }
  .hp-nav__brand .name { font: 400 22px/1 var(--pv-font-serif); letter-spacing: var(--pv-track-tight); }
  .hp-nav__meta { font: 400 11px/1 var(--pv-font-mono); text-transform: uppercase; letter-spacing: var(--pv-track-eyebrow); color: var(--pv-mute); display: flex; gap: var(--pv-5); align-items: center; }
  .hp-nav__meta a { color: var(--pv-ink-2); text-decoration: none; transition: color var(--pv-dur-1) var(--pv-ease); }
  .hp-nav__meta a:hover { color: var(--pv-sage); }
  .hp-nav__meta .live { display: inline-flex; align-items: center; gap: 6px; color: var(--pv-ink); }
  .hp-nav__meta .live i { width: 6px; height: 6px; border-radius: 50%; background: var(--pv-sage); box-shadow: 0 0 0 2px var(--pv-sage-tint); }

  /* hero */
  .hp-hero { padding: var(--pv-8) 0 var(--pv-7); }
  .hp-hero__greet { font: 400 11px/1 var(--pv-font-mono); text-transform: uppercase; letter-spacing: var(--pv-track-eyebrow); color: var(--pv-mute); margin-bottom: 24px; display: inline-flex; align-items: center; gap: 10px; }
  .hp-hero__greet i { width: 4px; height: 4px; background: var(--pv-sage); border-radius: 50%; }
  .hp-hero__title { font-family: var(--pv-font-serif); font-weight: 400; font-size: clamp(56px, 8vw, 104px); line-height: .94; letter-spacing: var(--pv-track-display); margin: 0 0 36px; max-width: 14ch; }
  .hp-hero__title em { font-style: italic; color: var(--pv-sage); }
  .hp-hero__intro { display: grid; grid-template-columns: 1.1fr .9fr; gap: 48px; align-items: start; }
  .hp-hero__intro p { font-size: 16.5px; line-height: 1.62; color: var(--pv-ink-2); margin: 0; max-width: 50ch; }
  .hp-hero__intro p + p { margin-top: 14px; }
  .hp-hero__intro p a { color: var(--pv-sage); text-decoration: underline; text-underline-offset: 4px; text-decoration-thickness: 1px; }

  .hp-card-tags { background: var(--pv-paper); border: 1px solid var(--pv-line); border-radius: var(--pv-r-1); padding: 18px 20px; }
  .hp-card-tags__head { font: 400 11px/1 var(--pv-font-mono); text-transform: uppercase; letter-spacing: var(--pv-track-eyebrow); color: var(--pv-mute); margin-bottom: 14px; display: flex; justify-content: space-between; }
  .hp-card-tags__list { display: flex; flex-wrap: wrap; gap: 6px; }
  .hp-card-tags__list a { display: inline-flex; align-items: center; gap: 5px; padding: 3px 9px; border: 1px solid var(--pv-line); border-radius: var(--pv-r-pill); font: 400 11.5px/1.6 var(--pv-font-mono); color: var(--pv-ink-2); background: var(--pv-bg); text-decoration: none; transition: border-color var(--pv-dur-1) var(--pv-ease), color var(--pv-dur-1) var(--pv-ease); }
  .hp-card-tags__list a:hover { border-color: var(--pv-sage); color: var(--pv-sage); }
  .hp-card-tags__list a .n { color: var(--pv-mute); font-size: 10.5px; }

  /* section header */
  .hp-sec { padding-top: var(--pv-8); }
  .hp-sec__head { display: flex; align-items: baseline; justify-content: space-between; padding-bottom: 18px; border-bottom: 1px solid var(--pv-line); margin-bottom: var(--pv-5); }
  .hp-sec__title { display: flex; align-items: baseline; gap: 16px; }
  .hp-sec__num { font: 400 12px/1 var(--pv-font-mono); color: var(--pv-sage); letter-spacing: var(--pv-track-eyebrow); text-transform: uppercase; }
  .hp-sec__name { font-family: var(--pv-font-serif); font-size: 38px; line-height: 1; letter-spacing: var(--pv-track-tight); font-weight: 400; }
  .hp-sec__count { font: 400 11px/1 var(--pv-font-mono); color: var(--pv-mute); text-transform: uppercase; letter-spacing: var(--pv-track-eyebrow); }

  /* project rows */
  .hp-proj { display: grid; grid-template-columns: 56px 1fr auto; gap: 24px; align-items: start; padding: 22px 0; border-bottom: 1px solid var(--pv-line); text-decoration: none; color: inherit; transition: background var(--pv-dur-1) var(--pv-ease); position: relative; }
  .hp-proj:hover { background: var(--pv-paper); }
  .hp-proj:hover .hp-proj__name { color: var(--pv-sage); }
  .hp-proj:hover .hp-proj__arrow { transform: translateX(3px); color: var(--pv-sage); }
  .hp-proj__id { font: 400 11px/1.4 var(--pv-font-mono); color: var(--pv-mute); letter-spacing: var(--pv-track-eyebrow); text-transform: uppercase; padding-top: 3px; }
  .hp-proj__body { min-width: 0; }
  .hp-proj__head { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; margin-bottom: 6px; }
  .hp-proj__name { font: 500 19px/1.2 var(--pv-font-sans); letter-spacing: var(--pv-track-tight); color: var(--pv-ink); transition: color var(--pv-dur-1) var(--pv-ease); }
  .hp-proj__name .v { color: var(--pv-mute); font-weight: 400; }
  .hp-proj__status { display: inline-flex; align-items: center; gap: 5px; font: 400 10.5px/1 var(--pv-font-mono); text-transform: uppercase; letter-spacing: var(--pv-track-eyebrow); padding: 3px 8px; border-radius: var(--pv-r-pill); border: 1px solid var(--pv-line); color: var(--pv-ink-2); }
  .hp-proj__status i { width: 5px; height: 5px; border-radius: 50%; background: var(--pv-mute); }
  .hp-proj__status--live i { background: var(--pv-sage); box-shadow: 0 0 0 2px var(--pv-sage-tint); }
  .hp-proj__status--build i { background: var(--pv-coral); }
  .hp-proj__status--draft i { background: var(--pv-line); }
  .hp-proj__status--shipped i { background: var(--pv-sage-soft); }
  .hp-proj__desc { font-size: 14.5px; line-height: 1.55; color: var(--pv-ink-2); margin: 0; max-width: 62ch; }
  .hp-proj__meta { display: flex; gap: 14px; margin-top: 10px; font: 400 11.5px/1 var(--pv-font-mono); color: var(--pv-mute); letter-spacing: 0; flex-wrap: wrap; }
  .hp-proj__meta .k { color: var(--pv-mute); }
  .hp-proj__meta .v { color: var(--pv-ink-2); }
  .hp-proj__date { font: 400 11.5px/1.4 var(--pv-font-mono); color: var(--pv-mute); white-space: nowrap; padding-top: 4px; }
  .hp-proj__arrow { display: inline-block; margin-left: 6px; color: var(--pv-mute); transition: transform var(--pv-dur-1) var(--pv-ease), color var(--pv-dur-1) var(--pv-ease); }

  /* notes (writing) — editorial */
  .hp-note { display: grid; grid-template-columns: 88px 1fr auto; gap: 24px; padding: 18px 0; border-bottom: 1px solid var(--pv-line); align-items: baseline; text-decoration: none; color: inherit; transition: background var(--pv-dur-1) var(--pv-ease); }
  .hp-note:hover { background: var(--pv-paper); }
  .hp-note:hover .hp-note__title { color: var(--pv-sage); }
  .hp-note__date { font: 400 11px/1 var(--pv-font-mono); color: var(--pv-mute); letter-spacing: var(--pv-track-eyebrow); text-transform: uppercase; }
  .hp-note__title { font-family: var(--pv-font-serif); font-size: 22px; line-height: 1.2; letter-spacing: var(--pv-track-tight); transition: color var(--pv-dur-1) var(--pv-ease); }
  .hp-note__title em { font-style: italic; color: var(--pv-sage); }
  .hp-note__read { font: 400 11px/1 var(--pv-font-mono); color: var(--pv-mute); letter-spacing: var(--pv-track-eyebrow); text-transform: uppercase; white-space: nowrap; }

  /* now playing */
  .hp-now { display: grid; grid-template-columns: 1.05fr .95fr; gap: 32px; align-items: start; padding: var(--pv-6) 0 0; }
  .hp-now__body { padding-top: 4px; }
  .hp-now__quote { font-family: var(--pv-font-serif); font-style: italic; font-size: 26px; line-height: 1.25; letter-spacing: var(--pv-track-tight); color: var(--pv-ink); border-left: 2px solid var(--pv-sage); padding-left: 18px; margin: 0 0 16px; }
  .hp-now__sub { font-size: 14.5px; line-height: 1.55; color: var(--pv-ink-2); max-width: 50ch; margin: 0; }

  .hp-now__panel { background: var(--pv-paper); border: 1px solid var(--pv-line); border-radius: var(--pv-r-1); padding: 18px 20px; }
  .hp-now__panel-head { display: flex; justify-content: space-between; align-items: center; padding-bottom: 12px; margin-bottom: 12px; border-bottom: 1px solid var(--pv-line); font: 400 11px/1 var(--pv-font-mono); text-transform: uppercase; letter-spacing: var(--pv-track-eyebrow); color: var(--pv-mute); }
  .hp-now__panel-head .right { color: var(--pv-ink-2); display: inline-flex; align-items: center; gap: 6px; }
  .hp-now__panel-head .right i { width: 5px; height: 5px; border-radius: 50%; background: var(--pv-sage); box-shadow: 0 0 0 2px var(--pv-sage-tint); }
  .hp-now__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  .hp-now__list li { display: grid; grid-template-columns: 18px 1fr auto; gap: 10px; align-items: center; font-size: 14px; }
  .hp-now__list li .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--pv-sage-soft); justify-self: center; }
  .hp-now__list li.shipped .dot { background: var(--pv-sage); }
  .hp-now__list li.queued .dot { background: var(--pv-line); }
  .hp-now__list li .label { color: var(--pv-ink); }
  .hp-now__list li .label em { color: var(--pv-mute); font-style: normal; font: 400 11.5px/1 var(--pv-font-mono); }
  .hp-now__list li .when { font: 400 11.5px/1 var(--pv-font-mono); color: var(--pv-mute); text-transform: uppercase; letter-spacing: var(--pv-track-eyebrow); }

  /* roadmap row — small terminal */
  .hp-term-wrap { margin-top: 20px; }

  /* footer */
  .hp-foot { margin-top: var(--pv-8); padding-top: var(--pv-5); border-top: 1px solid var(--pv-ink); display: flex; justify-content: space-between; align-items: end; flex-wrap: wrap; gap: 24px; }
  .hp-foot__signoff { font-family: var(--pv-font-serif); font-size: 28px; line-height: 1.1; max-width: 22ch; letter-spacing: var(--pv-track-tight); }
  .hp-foot__signoff em { font-style: italic; color: var(--pv-sage); }
  .hp-foot__links { display: flex; flex-direction: column; gap: 6px; text-align: right; font: 400 12px/1.4 var(--pv-font-mono); color: var(--pv-mute); }
  .hp-foot__links a { color: var(--pv-ink-2); text-decoration: none; }
  .hp-foot__links a:hover { color: var(--pv-sage); }
  .hp-foot__colophon { font: 400 11px/1.4 var(--pv-font-mono); color: var(--pv-mute); text-transform: uppercase; letter-spacing: var(--pv-track-eyebrow); margin-top: 24px; width: 100%; padding-top: 18px; border-top: 1px solid var(--pv-line); display: flex; justify-content: space-between; }

  @media (max-width: 720px) {
    .hp { padding: var(--pv-5) var(--pv-4) var(--pv-8); }
    .hp-nav { gap: 12px; }
    .hp-nav__meta { gap: 14px; font-size: 10px; }
    .hp-nav__meta .live { display: none; }
  }
  @media (max-width: 480px) {
    .hp-nav__brand .name { display: none; }
    .hp-nav__meta { gap: 12px; font-size: 10px; }
    .hp-hero__intro, .hp-now { grid-template-columns: 1fr; }
    .hp-proj { grid-template-columns: 44px 1fr; }
    .hp-proj__date { display: none; }
    .hp-note { grid-template-columns: 72px 1fr; }
    .hp-note__read { display: none; }
    .hp-foot { flex-direction: column; align-items: flex-start; }
    .hp-foot__links { text-align: left; }
  }
</style>
